[:project
 [{n_name n.5/n_name} revenue]
 [:order-by
  [[revenue {:direction :desc, :null-ordering :nulls-first}]]
  [:project
   [n.5/n_name {revenue _sum_out_7}]
   [:group-by
    [n.5/n_name {_sum_out_7 (sum _sum_in_8)}]
    [:map
     [{_sum_in_8 (* l.3/l_extendedprice (- 1 l.3/l_discount))}]
     [:mega-join
      [{n.5/regionkey r.6/regionkey}
       {s.4/nationkey n.5/nationkey}
       {l.3/suppkey s.4/suppkey}
       {c.1/nationkey s.4/nationkey}
       {o.2/orderkey l.3/orderkey}
       {c.1/custkey o.2/custkey}]
      [[:rename
        r.6
        [:scan
         {:table public/region}
         [{r_name (= r_name "ASIA")} regionkey]]]
       [:rename
        n.5
        [:scan {:table public/nation} [nationkey n_name regionkey]]]
       [:rename
        s.4
        [:scan {:table public/supplier} [nationkey suppkey]]]
       [:rename
        l.3
        [:scan
         {:table public/lineitem}
         [l_discount l_extendedprice suppkey orderkey]]]
       [:rename
        c.1
        [:scan {:table public/customer} [nationkey custkey]]]
       [:rename
        o.2
        [:scan
         {:table public/orders}
         [{o_orderdate
           (and
            (<
             o_orderdate
             (+
              #xt/date "1994-01-01"
              (single-field-interval "1" "YEAR" 2 6)))
            (>= o_orderdate #xt/date "1994-01-01"))}
          custkey
          orderkey]]]]]]]]]]
