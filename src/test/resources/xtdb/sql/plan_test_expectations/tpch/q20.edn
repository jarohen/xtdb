[:project
 [{s_name s.1/s_name} {s_address s.1/s_address}]
 [:order-by
  [[s.1/s_name {:direction :asc, :null-ordering :nulls-last}]]
  [:project
   [s.1/s_name s.1/s_address]
   [:map
    [{_sq_3 true}]
    [:mega-join
     [{s.1/nationkey n.2/nationkey}]
     [[:semi-join
       [{s.1/suppkey suppkey}]
       [:rename
        s.1
        [:scan
         {:table public/supplier}
         [s_name nationkey s_address suppkey]]]
       [:project
        [{suppkey ps.4/suppkey}]
        [:map
         [{_sq_5 true}]
         [:semi-join
          [{ps.4/partkey partkey}]
          [:select
           (> ps.4/ps_availqty _sq_7)
           [:map
            [{_sq_7 (* 0.5 _sum_out_11)}]
            [:group-by
             [ps.4/ps_availqty
              ps.4/partkey
              ps.4/suppkey
              _row_number_0
              {_sum_out_11 (sum l.8/l_quantity)}]
             [:left-outer-join
              [{ps.4/partkey l.8/partkey} {ps.4/suppkey l.8/suppkey}]
              [:map
               [{_row_number_0 (row-number)}]
               [:rename
                ps.4
                [:scan
                 {:table public/partsupp}
                 [ps_availqty partkey suppkey]]]]
              [:rename
               l.8
               [:scan
                {:table public/lineitem}
                [{l_shipdate
                  (and
                   (<
                    l_shipdate
                    (+
                     #xt/date "1994-01-01"
                     (single-field-interval "1" "YEAR" 2 6)))
                   (>= l_shipdate #xt/date "1994-01-01"))}
                 l_quantity
                 partkey
                 suppkey]]]]]]]
          [:project
           [{partkey p.6/partkey}]
           [:rename
            p.6
            [:scan
             {:table public/part}
             [partkey {p_name (like p_name "forest%")}]]]]]]]]
      [:rename
       n.2
       [:scan
        {:table public/nation}
        [nationkey {n_name (= n_name "CANADA")}]]]]]]]]]
