[:top
 {:skip nil, :limit 10}
 [:project
  [{orderkey l.3/orderkey}
   {o_orderdate o.2/o_orderdate}
   {o_shippriority o.2/o_shippriority}
   revenue]
  [:order-by
   [[revenue {:direction :desc, :null-ordering :nulls-first}]
    [o.2/o_orderdate {:direction :asc, :null-ordering :nulls-last}]]
   [:project
    [l.3/orderkey
     o.2/o_orderdate
     o.2/o_shippriority
     {revenue _sum_out_4}]
    [:group-by
     [l.3/orderkey
      o.2/o_orderdate
      o.2/o_shippriority
      {_sum_out_4 (sum _sum_in_5)}]
     [:map
      [{_sum_in_5 (* l.3/l_extendedprice (- 1 l.3/l_discount))}]
      [:mega-join
       [{o.2/orderkey l.3/orderkey} {c.1/custkey o.2/custkey}]
       [[:rename
         l.3
         [:scan
          {:table public/lineitem}
          [{l_shipdate (> l_shipdate #xt/date "1995-03-15")}
           l_discount
           l_extendedprice
           orderkey]]]
        [:rename
         c.1
         [:scan
          {:table public/customer}
          [{c_mktsegment (= c_mktsegment "BUILDING")} custkey]]]
        [:rename
         o.2
         [:scan
          {:table public/orders}
          [o_shippriority
           {o_orderdate (< o_orderdate #xt/date "1995-03-15")}
           custkey
           orderkey]]]]]]]]]]]
