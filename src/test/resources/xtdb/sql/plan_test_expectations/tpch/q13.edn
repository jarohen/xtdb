[:order-by
 [[custdist {:direction :desc, :null-ordering :nulls-first}]
  [c_count {:direction :desc, :null-ordering :nulls-first}]]
 [:project
  [c_count {custdist _row_count_4}]
  [:group-by
   [c_count {_row_count_4 (row-count)}]
   [:project
    [c.1/custkey {c_count _count_out_3}]
    [:group-by
     [c.1/custkey {_count_out_3 (count o.2/orderkey)}]
     [:left-outer-join
      [{c.1/custkey o.2/custkey}
       (not (like o.2/o_comment "%special%requests%"))]
      [:rename c.1 [:scan {:table public/customer} [custkey]]]
      [:rename
       o.2
       [:scan
        {:table public/orders}
        [custkey orderkey o_comment]]]]]]]]]
