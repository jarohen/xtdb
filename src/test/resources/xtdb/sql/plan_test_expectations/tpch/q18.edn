[:top
 {:skip nil, :limit 100}
 [:project
  [{c_name c.1/c_name}
   {custkey c.1/custkey}
   {orderkey o.2/orderkey}
   {o_orderdate o.2/o_orderdate}
   {o_totalprice o.2/o_totalprice}
   sum_qty]
  [:order-by
   [[o.2/o_totalprice {:direction :desc, :null-ordering :nulls-first}]
    [o.2/o_orderdate {:direction :asc, :null-ordering :nulls-last}]]
   [:project
    [c.1/c_name
     c.1/custkey
     o.2/orderkey
     o.2/o_orderdate
     o.2/o_totalprice
     {sum_qty _sum_out_7}]
    [:group-by
     [c.1/c_name
      c.1/custkey
      o.2/orderkey
      o.2/o_orderdate
      o.2/o_totalprice
      {_sum_out_7 (sum l.3/l_quantity)}]
     [:map
      [{_sq_4 true}]
      [:mega-join
       [{o.2/orderkey l.3/orderkey} {c.1/custkey o.2/custkey}]
       [[:rename
         l.3
         [:scan {:table public/lineitem} [l_quantity orderkey]]]
        [:rename c.1 [:scan {:table public/customer} [c_name custkey]]]
        [:semi-join
         [{o.2/orderkey orderkey}]
         [:rename
          o.2
          [:scan
           {:table public/orders}
           [o_orderdate custkey orderkey o_totalprice]]]
         [:project
          [{orderkey l.5/orderkey}]
          [:select
           (> _sum_out_6 300)
           [:group-by
            [l.5/orderkey {_sum_out_6 (sum l.5/l_quantity)}]
            [:rename
             l.5
             [:scan
              {:table public/lineitem}
              [l_quantity orderkey]]]]]]]]]]]]]]]
